#!/usr/bin/make -f

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# debian/local-gguf is written by the packaging switch scripts:
#   enabled  — ollmchat (requires libllama at build time)
#   disabled — ollmchat-remote-only (no local GGUF backend)
LOCAL_GGUF := $(shell grep -E '^(enabled|disabled)$$' debian/local-gguf 2>/dev/null || echo enabled)

%:
	dh $@

override_dh_auto_configure:
	meson setup build --prefix=/usr -Ddocs=false -Dexamples=true -Dtests=false -Dlocal_gguf=$(LOCAL_GGUF)

override_dh_auto_build:
	ninja -C build

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/tmp ninja -C build install

override_dh_auto_test:
	# Tests can be run here if needed

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
