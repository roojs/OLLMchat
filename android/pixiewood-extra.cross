[json-glib:project options]
introspection = 'disabled'
documentation = 'disabled'

[libsoup:project options]
tests = false
introspection = 'disabled'
docs = 'disabled'
brotli = 'disabled'
gssapi = 'disabled'
ntlm = 'disabled'
# Cross builds cannot run libsoup's GIO TLS compile-time probe; runtime TLS
# comes from glib-networking (see GIO_MODULE_DIR in AndroidPoc.vala).
tls_check = false
sysprof = 'disabled'

[glib-networking:project options]
gnutls = 'disabled'
openssl = 'enabled'
libproxy = 'disabled'
gnome_proxy = 'disabled'
environment_proxy = 'enabled'
installed_tests = false

[libollmchat:project options]
docs = false
examples = false
tests = false
local_gguf = 'disabled'
android_poc = true

[ollmchat:project options]
docs = false
examples = false
tests = false
local_gguf = 'disabled'
android_poc = true
