<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/"
     xmlns:meta="https://specifications.freedesktop.org/metainfo/1.0">
  <metainfo vercalc="sem121010">
    <meta:component type="desktop-application">
      <meta:id>org.roojs.ollmchat.gtkfixespoc</meta:id>
      <meta:name>GTK Android Fixes</meta:name>
      <meta:summary>Minimal harness for GIO TLS backend registration</meta:summary>
      <meta:metadata_license>CC0-1.0</meta:metadata_license>
      <meta:project_license>LGPL-3.0-or-later</meta:project_license>
      <meta:description>
        <meta:p>
          Tiny GTK Android app that probes whether libgioopenssl.so
          registers a real GTlsBackend on device. IME and paste fixes are
          validated separately; this APK is TLS-only.
        </meta:p>
      </meta:description>
      <meta:requires>
        <meta:internet>always</meta:internet>
      </meta:requires>
      <meta:branding>
        <meta:color type="primary" scheme_preference="light">#3584e4</meta:color>
        <meta:color type="primary" scheme_preference="dark">#1c71d8</meta:color>
      </meta:branding>
      <meta:releases>
        <meta:release version="0.1.0" date="2026-06-16"/>
      </meta:releases>
    </meta:component>
  </metainfo>
  <style>
    <theme name="gtk"/>
    <icon type="generate">
      <drawable
        target="foreground"
        type="avd"
        path="src://android/icon-foreground.xml"/>
      <color target="background">#ffffff</color>
    </icon>
  </style>
  <dependencies>
    <glib>
      <patch>hack</patch>
    </glib>
    <fontconfig/>
    <gtk/>
    <nghttp2/>
    <libsoup/>
    <openssl/>
    <glib-networking/>
  </dependencies>
  <build target="ollmchat-android-gtk-fixes-poc">
    <configure-options>
      <option>-Dandroid_gtk_fixes_poc=true</option>
      <option>-Dandroid_poc=false</option>
      <option>-Dandroid_shell_poc=false</option>
      <option>-Ddocs=false</option>
      <option>-Dexamples=false</option>
      <option>-Dtests=false</option>
    </configure-options>
    <architectures>
      <arch>aarch64</arch>
    </architectures>
  </build>
</app>
