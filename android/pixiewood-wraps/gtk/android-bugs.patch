+static void
+gdk_android_preload_openssl_libs (const char *dir)
+{
+  static const char *candidates[] = {
+    "libcrypto.so",
+    "libssl.so",
+    "libcrypto.so.3",
+    "libssl.so.3",
+    NULL
+  };
+  gsize i;
+
+  if (dir == NULL || dir[0] == '\0')
+    return;
+
+  for (i = 0; candidates[i] != NULL; i++)
+    {
+      g_autofree char *path = g_build_filename (dir, candidates[i], NULL);
+
+      if (g_file_test (path, G_FILE_TEST_IS_REGULAR))
+        dlopen (path, RTLD_NOW | RTLD_GLOBAL);
+    }
+}
+
 static GThread *gtk_thread_s = NULL;
 
 static void
@@ -280,6 +306,20 @@ _gdk_android_application_start_runtime (JNIEnv  *env,
                    "XDG_DATA_HOME", userdatadir,
                    NULL);
 
+  /* writeResources() ran before startRuntime(); scan TLS modules while
+   * datadir is still known so HTTPS works on first libsoup use. */
+  {
+    gchar *gio_module_dir = g_build_filename (datadir, "gio", "modules", NULL);
+
+    if (g_file_test (gio_module_dir, G_FILE_TEST_IS_DIR))
+      {
+        gdk_android_preload_openssl_libs (gio_module_dir);
+        g_setenv ("GIO_MODULE_DIR", gio_module_dir, TRUE);
+        g_io_modules_scan_all_in_directory (gio_module_dir);
+      }
+    g_free (gio_module_dir);
+  }
+
   g_free (configdir);
   g_free (datadir);
   g_free (userconfigdir);
