diff --git a/gdk/android/gdkandroidruntime.c b/gdk/android/gdkandroidruntime.c
--- a/gdk/android/gdkandroidruntime.c
+++ b/gdk/android/gdkandroidruntime.c
@@ -19,6 +19,7 @@
 
 #include <glib.h>
 #include <gmodule.h>
+#include <gio/gio.h>
 
 #include <gdk/android/gdkandroid.h>
 #include <gdk/android/gdkandroidinit-private.h>
@@ -280,6 +281,19 @@ _gdk_android_application_start_runtime (JNIEnv  *env,
                    "XDG_DATA_HOME", userdatadir,
                    NULL);
 
+  /* writeResources() ran before startRuntime(); scan TLS modules while
+   * datadir is still known so HTTPS works on first libsoup use. */
+  {
+    gchar *gio_module_dir = g_build_filename (datadir, "gio", "modules", NULL);
+
+    if (g_file_test (gio_module_dir, G_FILE_TEST_IS_DIR))
+      {
+        g_setenv ("GIO_MODULE_DIR", gio_module_dir, TRUE);
+        g_io_modules_scan_all_in_directory (gio_module_dir);
+      }
+    g_free (gio_module_dir);
+  }
+
   g_free (configdir);
   g_free (datadir);
   g_free (userconfigdir);
diff --git a/gdk/android/gdkandroidollmchatpatch.c b/gdk/android/gdkandroidollmchatpatch.c
new file mode 100644
index 0000000000..e8f4a2b1c3
--- /dev/null
+++ b/gdk/android/gdkandroidollmchatpatch.c
@@ -0,0 +1,13 @@
+/*
+ * OLLMchat android-bugs.patch compile marker.
+ * CI/build logs should contain: gdkandroidollmchatpatch.c.o
+ * SPDX-License-Identifier: LGPL-2.1-or-later
+ */
+
+#include "config.h"
+
+/* Survives in libgtk-4.so; verify-apk.sh greps for this tag. */
+const char gdk_android_ollmchat_bugs_tag[] = "ollmchat-android-bugs-v1";
+
+static void
+gdk_android_ollmchat_patch_marker (void)
+{
+  /* Keep the tag referenced so release builds do not drop it. */
+  g_debug ("%s", gdk_android_ollmchat_bugs_tag);
+}

